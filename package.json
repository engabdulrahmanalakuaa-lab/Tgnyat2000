{
  "name": "technologies-soft-pro",
  "version": "2.0.0",
  "description": "نظام مطعم متكامل - تقنيات سوفت",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win --x64",
    "postinstall": "electron-builder install-app-deps",
    "rebuild": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.0.0",
    "node-thermal-printer": "^4.4.0",
    "pdfmake": "^0.2.7"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9"
  },
  "build": {
    "appId": "com.technologies-soft.pos",
    "productName": "تقنيات سوفت - مطعم",
    "asarUnpack": [
      "**/*.node"
    ],
    "win": {
      "target": "nsis",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "تقنيات سوفت"
    },
    "files": [
      "**/*",
      "!dist"
    ]
  }
}
